# Postgres "super admin"
PG_SUPERUSER=pgadmin
PG_SUPERPASS=devpassword123
PG_SUPERDB=postgres
PG_HOST_PORT=6100

# Keycloak DB creds (least privileged)
KC_DB_NAME=keycloakdb
KC_DB_USER=keycloak
KC_DB_PASS=devpassword123

# Keycloak admin UI user
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin
KC_HOST_PORT=6101

# App DB creds
APP_DB_NAME=qataskdb
APP_DB_USER=qataskuser
APP_DB_PASS=devpassword123

# Keycloak OIDC client secret (will be set after realm import)
KC_CLIENT_SECRET=qa-task-secret

# .NET Application Secrets
ConnectionStrings__QaTaskDb=Host=localhost;Port=6100;Database=qataskdb;Username=qataskuser;Password=devpassword123
Keycloak__ClientSecret=qa-task-secret
